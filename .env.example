BOT_TOKEN=123456:ABC-DEF...

# ID администратора(ов) бота через запятую — свой Telegram user id можно узнать у @userinfobot.
# Админам доступна команда /admin (все настройки БД/бэкапов/кэша/квот, список пользователей,
# рассылка, бэкап по требованию) — именно им бот шлёт файлы бэкапов в личные сообщения.
ADMIN_IDS=111111111,222222222

# Путь к БД (единый файл для всех владельцев)
DB_PATH=data/bot.db

# ---------------------------------------------------------------------------
# Всё остальное (интервал и хранение бэкапов, размер RAM-кэша, квота на медиа,
# сохранять ли вообще все сообщения в БД) — НЕ через .env. Это стартовые
# значения только для самого первого запуска (когда в БД ещё ничего нет);
# дальше эти же настройки редактируются на лету через /admin в чате с ботом,
# без передеплоя контейнера.
# ---------------------------------------------------------------------------
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=12
BACKUP_KEEP_LOCAL_HOURS=6
BACKUP_COMPRESS=true

CACHE_MAX_ENTRIES=800
CACHE_CLEANUP_INTERVAL_MIN=10

MEDIA_MAX_TOTAL_MB=2048

DEFAULT_STORE_ALL_MESSAGES=false

# Тексты бота (\n = перенос строки, HTML разрешён).
# Можно указать файл вместо переменной: TEXT_START_FILE=config/start.txt
# {admin_hint} в TEXT_START подставляется автоматически только для админов.
# TEXT_START=Привет!\n\n{admin_hint}
# TEXT_PONG=🏓 живой
