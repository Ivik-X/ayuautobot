BOT_TOKEN=123456:ABC-DEF...

# ID администратора(ов) бота через запятую — свой Telegram user id можно узнать у @userinfobot.
# Админам доступна команда /admin (все настройки БД/бэкапов/кэша/квот, список пользователей,
# рассылка, бэкап по требованию) — именно им бот шлёт файлы бэкапов в личные сообщения.
ADMIN_IDS=111111111,222222222

# Путь к БД (единый файл для всех владельцев)
DB_PATH=data/bot.db

# Цена подписки, пробный период и все лимиты бесплатного тарифа настраиваются
# ПОСЛЕ запуска через /admin в чате с ботом (не через .env) — см. README.

# ---------------------------------------------------------------------------
# Всё остальное (интервал и хранение бэкапов, размер RAM-кэша, квота на медиа,
# минимум свободного места на диске, цена и лимиты подписки) — НЕ через .env.
# Это стартовые значения только для самого первого запуска (когда в БД ещё
# ничего нет); дальше эти же настройки редактируются на лету через /admin в
# чате с ботом, без передеплоя контейнера. Сообщения теперь всегда пишутся в
# БД — за освобождение места отвечают бэкап по расписанию и аварийная очистка
# по нехватке места, а не отдельный тумблер "сохранять или нет".
# ---------------------------------------------------------------------------
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=12
BACKUP_KEEP_LOCAL_HOURS=6
BACKUP_COMPRESS=true

CACHE_MAX_ENTRIES=800
CACHE_CLEANUP_INTERVAL_MIN=10

MEDIA_MAX_TOTAL_MB=2048

# Если свободного места на диске меньше — аварийный бэкап + удаление самых
# старых записей, пока место не освободится.
MIN_FREE_DISK_GB=5

# ---------------------------------------------------------------------------
# Распознавание голосовых — ЛОКАЛЬНО (faster-whisper, без внешних API и
# без затрат). Расшифровывает только гс/кружки/аудио, которые вы сами
# отправили боту напрямую в личку (не всё подряд в бизнес-чате).
# Выключено по умолчанию: модель качается при первом использовании
# (~150 МБ для base) и держит часть RAM, пока бот запущен.
# tiny/base — для слабого сервера, small/medium/large-v3 — если ресурсов хватает.
# STT_LANGUAGE пустой = автоопределение языка; можно жёстко задать "ru".
# ---------------------------------------------------------------------------
STT_ENABLED=false
STT_MODEL_SIZE=base
STT_LANGUAGE=

# ---------------------------------------------------------------------------
# Слежение за профилями (.watch/.unwatch) — как часто опрашивать getChat.
# ---------------------------------------------------------------------------
PROFILE_WATCH_INTERVAL_MIN=30

# ---------------------------------------------------------------------------
# Webhook вместо long polling (опционально, но снижает задержку доставки
# апдейтов — актуально для гонки со скачиванием одноразовых медиа).
# Нужен публичный HTTPS-домен (например, за nginx + Let's Encrypt).
# Если WEBHOOK_URL пуст — бот работает через обычный polling, как раньше.
# ---------------------------------------------------------------------------
WEBHOOK_URL=
WEBHOOK_PATH=/webhook
WEBHOOK_SECRET=
WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=8080

# Тексты бота (\n = перенос строки, HTML разрешён).
# Можно указать файл вместо переменной: TEXT_START_FILE=config/start.txt
# {admin_hint} в TEXT_START подставляется автоматически только для админов.
# TEXT_START=Привет!\n\n{admin_hint}
# TEXT_PONG=🏓 живой
