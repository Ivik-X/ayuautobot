BOT_TOKEN=123456:ABC-DEF...

# ID администратора(ов) бота через запятую — свой Telegram user id можно узнать у @userinfobot
# Админам доступны: /admin, /users, /backupnow, /broadcast — и именно им бот
# присылает бэкапы БД в личные сообщения.
ADMIN_IDS=111111111,222222222

# --- Кэш в оперативной памяти (быстрый горячий слой перед SQLite) ---
CACHE_MAX_ENTRIES=800
CACHE_CLEANUP_INTERVAL_MIN=10

# --- Лимит на диск для сохранённых медиафайлов (защита 10 GB NVMe) ---
MEDIA_MAX_TOTAL_MB=2048

# --- Автобэкап БД: снимок -> в ЛС админам -> схлопнуть локальную историю ---
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=12
BACKUP_KEEP_LOCAL_HOURS=6
BACKUP_COMPRESS=true

# --- Значения по умолчанию для новых владельцев бизнес-подключений ---
# Каждый владелец может переопределить их себе через /settings или .set
DEFAULT_CACHE_TTL_HOURS=24
DEFAULT_STORE_HISTORY=true
DEFAULT_SAVE_MEDIA=true
DEFAULT_NOTIFY_EDIT=true
DEFAULT_NOTIFY_DELETE=true
DEFAULT_MUTE_SECONDS=60

# Путь к БД (единый файл для всех владельцев)
DB_PATH=data/bot.db

# Тексты бота (\n = перенос строки, HTML разрешён)
# Можно указать файл вместо переменной: TEXT_START_FILE=config/start.txt
# TEXT_START=Привет!\n\n{help}
# TEXT_HELP=<b>Мои команды</b>...
# TEXT_PONG=🏓 живой
